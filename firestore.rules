rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Applications ──────────────────────────────────────────────────────────
    // Any authenticated user may CREATE an application.
    // Users may READ their own applications.
    // Admin (by email) may READ and UPDATE any application.
    match /applications/{docId} {
      allow create: if request.auth != null;

      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        request.auth.token.email in ['traveliumgrobal@gmail.com', 'samlite250@gmail.com']
      );

      allow update: if request.auth != null &&
        request.auth.token.email in ['traveliumgrobal@gmail.com', 'samlite250@gmail.com'];

      allow delete: if false; // never allow deletion
    }

    // ── User profiles (future) ────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
